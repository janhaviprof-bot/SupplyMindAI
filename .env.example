# OpenAI (required for analysis pipeline)
OPENAI_API_KEY=sk-...

# --- Supabase Postgres (pick one style) ---

# A) Single var (any URI Supabase gives you):
# POSTGRES_CONNECTION_STRING=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# B) Supabase Dashboard → Connect → ORM (Prisma-style). Replace YOUR_PASSWORD — do not use square brackets.
#    Host may be aws-0-REGION or aws-1-REGION depending on project; copy exactly from the dashboard.
#    Port 5432 = session mode (best for this app + copy_from_peer on Windows).
#    Port 6543 = transaction pooler (pgbouncer); fine for many queries, not for long migrations.
#
# DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# This app resolves DB URL in order: POSTGRES_CONNECTION_STRING → DIRECT_URL → DATABASE_URL

# Optional: limit in-transit shipments for demos
# MAX_SHIPMENTS=8

# One-time peer copy (py SupplyMindAI/supplymind_db/copy_from_peer.py from repo root): friend’s DB + your target (same vars as above for “your” side)
# SOURCE_POSTGRES_CONNECTION_STRING=postgresql://postgres.THEIR_REF:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# --- What-If advisor (DS-AIforSystemsEng-style: agents, RAG, tools, MCP) ---
# MCP URL is required for advisor tools (Shiny calls tools via HTTP only).
# Local:
# SUPPLYMIND_MCP_URL=http://127.0.0.1:8765/mcp
# Cornell Posit Connect (use /content/.../mcp for Shiny Variables — not the Connect UI URL):
# SUPPLYMIND_MCP_URL=https://connect.systems-apps.com/content/4684a7e7-6271-47d8-aacd-d4805850d51f/mcp
# Connect dashboard (same deployment): https://connect.systems-apps.com/connect/#/apps/4684a7e7-6271-47d8-aacd-d4805850d51f/content-view

# Planner: json (single JSON completion) or openai_tools (function-calling loop + submit_planner_decision)
# ADVISOR_PLANNER_MODE=json
# ADVISOR_PLANNER_MODE=openai_tools

# RAG: keyword (default), embed (OpenAI text-embedding-3-small), hybrid
# RAG_RETRIEVAL_MODE=keyword
# RAG_RETRIEVAL_MODE=embed
# RAG_RETRIEVAL_MODE=hybrid

# Run MCP server from inner SupplyMindAI folder:
#   uvicorn mcp_server.server:app --host 127.0.0.1 --port 8765 --reload
